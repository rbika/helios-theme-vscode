  "tokenColors": [
    { "settings": { "foreground": "#5e727a" } },
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": { "foreground": "#5e727a" }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": { "fontStyle": "italic", "foreground": "#8f9da3" }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": { "foreground": "#00998C" }
    },
    {
      "name": "Regexp",
      "scope": "string.regexp",
      "settings": { "foreground": "#00998C" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#CC3B81" }
    },
    {
      "name": "Variable",
      "scope": ["variable.language"],
      "settings": { "foreground": "#007AC0" }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": { "fontStyle": "", "foreground": "#946F00" }
    },
    {
      "name": "Function name",
      "scope": "entity.name.function",
      "settings": { "foreground": "#007AC0" }
    },
    {
      "name": "Variable start",
      "scope": "punctuation.definition.variable",
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Embedded code markers",
      "scope": [
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": { "foreground": "#00ff00" } // TODO
    },
    {
      "name": "Built-in constant",
      "scope": ["constant.language", "meta.preprocessor"],
      "settings": { "foreground": "#CC3B81" }
    },
    {
      "name": "Support.construct",
      "scope": ["support.function.construct", "keyword.other.new"],
      "settings": { "foreground": "#00ff00" } // TODO
    },
    {
      "name": "User-defined constant",
      "scope": ["constant.character", "constant.other"],
      "settings": { "foreground": "#00998C" }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class",
        "punctuation.separator.namespace.ruby"
      ],
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Function argument",
      "scope": "variable.parameter",
      "settings": {}
    },
    {
      "name": "Tag name",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#007AC0" }
    },
    {
      "name": "Tag start/end",
      "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#8f9da3" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#007AC0" }
    },
    {
      "name": "Library function",
      "scope": "support.function",
      "settings": { "foreground": "#007AC0" }
    },
    {
      "name": "Continuation",
      "scope": "punctuation.separator.continuation",
      "settings": { "foreground": "#8f9da3" }
    },
    {
      "name": "Library constant",
      "scope": ["support.constant", "support.variable"],
      "settings": {}
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.class"],
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Library Exception",
      "scope": "support.type.exception",
      "settings": { "foreground": "#2587CC" }
    },
    {
      "name": "Library variable",
      "scope": "support.other.variable",
      "settings": {}
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#DC322F" } // TODO
    },
    // ----------
    {
      "name": "diff: header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": { "fontStyle": "italic", "foreground": "#007AC0" }
    },
    {
      "name": "diff: deleted",
      "scope": "markup.deleted",
      "settings": { "fontStyle": "", "foreground": "#DC322F" }
    },
    {
      "name": "diff: changed",
      "scope": "markup.changed",
      "settings": { "fontStyle": "", "foreground": "#CB4B16" }
    },
    {
      "name": "diff: inserted",
      "scope": "markup.inserted",
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Markup Quote",
      "scope": "markup.quote",
      "settings": { "foreground": "#946F00" }
    },
    {
      "name": "Markup Lists",
      "scope": "markup.list",
      "settings": { "foreground": "#B58900" }
    },
    {
      "name": "Markup Styling",
      "scope": ["markup.bold", "markup.italic"],
      "settings": { "foreground": "#CC3B81" }
    },
    {
      "name": "Markup: Strong",
      "scope": "markup.bold",
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markup: Emphasis",
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": "markup.strikethrough",
      "settings": { "fontStyle": "strikethrough" }
    },
    {
      "name": "Markup Inline",
      "scope": "markup.inline.raw",
      "settings": { "fontStyle": "", "foreground": "#00998C" }
    },
    {
      "name": "Markup Headings",
      "scope": "markup.heading",
      "settings": { "fontStyle": "bold", "foreground": "#007AC0" }
    },
    {
      "name": "Markup Setext Header",
      "scope": "markup.heading.setext",
      "settings": { "fontStyle": "", "foreground": "#007AC0" }
    }
  ]
}
